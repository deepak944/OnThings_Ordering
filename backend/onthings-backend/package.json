{
  "name": "onthings-backend",
  "version": "1.0.0",
  "description": "Production-ready e-commerce backend for OnThings",
  "main": "server.js",
  "scripts": {
    "init:db": "node scripts/initDatabase.js",
    "dev": "nodemon server.js",
    "start": "node server.js",
    "start:docker": "node scripts/waitForDatabase.js && node server.js",
    "seed:products": "node scripts/seedProducts.js",
    "update:order-status": "node scripts/updateOrderStatus.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-validator": "^7.2.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.5",
    "nodemailer": "^6.9.16",
    "razorpay": "^2.9.4",
    "sequelize": "^6.37.5",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
